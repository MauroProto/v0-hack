MAX_SCAN_FILES=500
MAX_SCAN_FILE_SIZE_BYTES=500000
MAX_SCAN_TOTAL_SIZE_BYTES=10000000
MAX_SCAN_FILES_MAX=900
MAX_SCAN_TOTAL_SIZE_BYTES_MAX=20000000
MAX_SCAN_LOCKFILE_SIZE_BYTES=2000000
BADGER_ENABLE_OSV=true
MAX_OSV_PACKAGES=150
OSV_TIMEOUT_MS=8000
BADGER_MONTHLY_SCAN_QUOTA=20
# Local development only; ignored when NODE_ENV=production or VERCEL=1.
BADGER_DISABLE_LOCAL_RATE_LIMITS=false
BADGER_SCAN_BURST_LIMIT=6
BADGER_EXPLAIN_BURST_LIMIT=10
BADGER_PULL_REQUEST_BURST_LIMIT=3
BADGER_BURST_WINDOW_SECONDS=60
BADGER_IDENTITY_SALT=
BADGER_GITHUB_SESSION_SECRET=

# Clerk app account auth. Public scans still work without login; Clerk ties dashboard/report history to a user account.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Server-side GitHub OAuth. The GitHub token is stored in an encrypted HttpOnly cookie, never in browser JS.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
# Preferred: server-side GitHub App for public repo scans without user login.
BADGER_GITHUB_APP_ID=
BADGER_GITHUB_APP_INSTALLATION_ID=
BADGER_GITHUB_APP_PRIVATE_KEY=
# Temporary fallback for repeated public repo scans without hitting GitHub's anonymous API limit.
BADGER_GITHUB_TOKEN=
# Local development only; ignored when NODE_ENV=production or VERCEL=1.
BADGER_ALLOW_LOCAL_GITHUB_TOKEN=true

# Supabase persistence is optional locally. If missing, Badger falls back to a git-ignored local file store.
# v0/Vercel Supabase integrations usually provide NEXT_PUBLIC_SUPABASE_URL and an anon/publishable key.
# Badger needs a server-only service key to write scan reports without public table policies.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional server-only alternative accepted by some Supabase/Vercel integrations.
SUPABASE_SECRET_KEY=
# Keep true in production so the 20 scans/month quota cannot fall back to memory.
BADGER_REQUIRE_PERSISTENT_QUOTA=true
BADGER_REQUIRE_PERSISTENT_STORAGE=true
BADGER_ENABLE_BACKGROUND_JOBS=false
BADGER_WORKER_SECRET=
BADGER_LOCAL_STORE_FILE=scan-reports.json

# Keep false. Report listing is filtered by request identity.
BADGER_ENABLE_PUBLIC_SCAN_LIST=false
BADGER_ALLOW_LEGACY_REPORT_ACCESS=false
# Keep false in production unless an operator-only context needs detailed config booleans.
BADGER_PUBLIC_HEALTH_DETAILS=false

# AI provider selection. Use one of: gateway, anthropic, deepseek.
# If unset, Badger tries AI Gateway first, then Anthropic, then DeepSeek.
BADGER_AI_PROVIDER=anthropic
BADGER_ENABLE_AI_REVIEW=true
BADGER_AI_REVIEW_MAX_FILES=18
BADGER_AI_REVIEW_MAX_FILES_MAX=42
BADGER_AI_REVIEW_CONTEXT_CHARS=28000
BADGER_AI_REVIEW_CONTEXT_CHARS_MAX=58000
BADGER_AI_REVIEW_FINDINGS=6
BADGER_AI_REVIEW_FINDINGS_MAX=10
BADGER_AI_REVIEW_TIMEOUT_MS=30000
BADGER_AI_REVIEW_MAX_TIMEOUT_MS=60000
BADGER_ALLOW_PRIVATE_AI_REVIEW=false

# AI Gateway option.
AI_GATEWAY_API_KEY=
BADGER_MODEL=openai/gpt-5.2-mini

# Claude / Anthropic option. Keep server-only; never use NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
BADGER_ANTHROPIC_MODEL=claude-opus-4-7
BADGER_ANTHROPIC_EFFORT=xhigh
# Mandatory PR safety gate. Pull requests fail closed if Claude is unavailable.
BADGER_PR_REVIEW_MODEL=claude-opus-4-7
BADGER_PR_REVIEW_EFFORT=max
BADGER_PR_REVIEW_TIMEOUT_MS=180000

# DeepSeek option. Keep server-only; never use NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
BADGER_DEEPSEEK_MODEL=deepseek-v4-pro
BADGER_DEEPSEEK_REASONING_EFFORT=high

# Legacy VIBESHIELD_* variables are still accepted for existing deployments.
