MAX_SCAN_FILES=500
MAX_SCAN_FILE_SIZE_BYTES=500000
MAX_SCAN_TOTAL_SIZE_BYTES=10000000
MAX_SCAN_FILES_MAX=900
MAX_SCAN_TOTAL_SIZE_BYTES_MAX=20000000
VIBESHIELD_MONTHLY_SCAN_QUOTA=20
VIBESHIELD_DISABLE_LOCAL_RATE_LIMITS=true
VIBESHIELD_SCAN_BURST_LIMIT=6
VIBESHIELD_EXPLAIN_BURST_LIMIT=10
VIBESHIELD_PULL_REQUEST_BURST_LIMIT=3
VIBESHIELD_BURST_WINDOW_SECONDS=60
VIBESHIELD_IDENTITY_SALT=
VIBESHIELD_GITHUB_SESSION_SECRET=

# Server-side GitHub OAuth. The GitHub token is stored in an encrypted HttpOnly cookie, never in browser JS.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
# Optional local-only fallback for repeated public repo scans without hitting GitHub's anonymous API limit.
VIBESHIELD_GITHUB_TOKEN=
VIBESHIELD_ALLOW_LOCAL_GITHUB_TOKEN=true

# Supabase persistence is optional locally. If missing, VibeShield falls back to a git-ignored local file store.
# v0/Vercel Supabase integrations usually provide NEXT_PUBLIC_SUPABASE_URL and an anon/publishable key.
# VibeShield needs a server-only service key to write scan reports without public table policies.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Keep true in production so the 20 scans/month quota cannot fall back to memory.
VIBESHIELD_REQUIRE_PERSISTENT_QUOTA=true
VIBESHIELD_REQUIRE_PERSISTENT_STORAGE=true

# Keep false. Report listing is filtered by request identity.
VIBESHIELD_ENABLE_PUBLIC_SCAN_LIST=false
VIBESHIELD_ALLOW_LEGACY_REPORT_ACCESS=false

# AI provider selection. Use one of: gateway, anthropic, deepseek.
# If unset, VibeShield tries AI Gateway first, then Anthropic, then DeepSeek.
VIBESHIELD_AI_PROVIDER=anthropic
VIBESHIELD_ENABLE_AI_REVIEW=true
VIBESHIELD_AI_REVIEW_MAX_FILES=18
VIBESHIELD_AI_REVIEW_MAX_FILES_MAX=42
VIBESHIELD_AI_REVIEW_CONTEXT_CHARS=28000
VIBESHIELD_AI_REVIEW_CONTEXT_CHARS_MAX=58000
VIBESHIELD_AI_REVIEW_FINDINGS=6
VIBESHIELD_AI_REVIEW_FINDINGS_MAX=10
VIBESHIELD_AI_REVIEW_TIMEOUT_MS=30000
VIBESHIELD_AI_REVIEW_MAX_TIMEOUT_MS=30000
VIBESHIELD_ALLOW_PRIVATE_AI_REVIEW=false

# AI Gateway option.
AI_GATEWAY_API_KEY=
VIBESHIELD_MODEL=openai/gpt-5.2-mini

# Claude / Anthropic option. Keep server-only; never use NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
VIBESHIELD_ANTHROPIC_MODEL=claude-sonnet-4-5

# DeepSeek option. Keep server-only; never use NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
VIBESHIELD_DEEPSEEK_MODEL=deepseek-v4-pro
VIBESHIELD_DEEPSEEK_REASONING_EFFORT=high
